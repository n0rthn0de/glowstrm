<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The Threshold · GlowStrm</title>
<meta name="description" content="The threshold into GlowStrm's client work. Cross it, and you step through to your private Stargate — a world built around your work.">
<meta name="theme-color" content="#271F41">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;0,700;1,500;1,600&family=Source+Sans+3:wght@300;400;600&display=swap" rel="stylesheet">
<style>
:root{
  --void:#1a1030; --charcoal:#271F41; --charcoal-2:#2f2450;
  --gold:#E6B65C; --gold-soft:#f3d99b;
  --cream:#F7F3EC; --muted:#c9c0dd;
  --plum:#783E8D; --violet:#774ECE; --rose:#BB4072; --coral:#FB896D;
  --line:rgba(230,182,92,.22);
  --card:rgba(255,255,255,.045);
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{
  font-family:'Source Sans 3',-apple-system,system-ui,sans-serif;
  color:var(--cream); background:var(--charcoal);
  line-height:1.65; -webkit-font-smoothing:antialiased; overflow-x:hidden;
}
/* cosmos */
.sky{position:fixed;inset:0;z-index:-2;
  background:
    radial-gradient(1200px 700px at 50% -10%, rgba(119,78,206,.28), transparent 60%),
    radial-gradient(900px 600px at 85% 20%, rgba(187,64,114,.16), transparent 55%),
    radial-gradient(1000px 700px at 10% 80%, rgba(230,182,92,.10), transparent 55%),
    linear-gradient(180deg, var(--void), var(--charcoal) 55%, #201839);
}
#stars{position:fixed;inset:0;z-index:-1;pointer-events:none}
.star{position:absolute;background:#fff;border-radius:50%;opacity:.7;animation:tw var(--d,4s) ease-in-out infinite alternate}
@keyframes tw{from{opacity:.15}to{opacity:.9}}

.wrap{max-width:1000px;margin:0 auto;padding:0 24px}
.kicker{font-size:12px;font-weight:600;letter-spacing:.32em;text-transform:uppercase;color:var(--gold);
  display:flex;gap:12px;justify-content:center;flex-wrap:wrap;align-items:center}
.kicker .dot{color:rgba(230,182,92,.5)}

/* header */
header{position:relative;z-index:2;display:flex;justify-content:space-between;align-items:center;
  max-width:1000px;margin:0 auto;padding:22px 24px}
header .brand{display:flex;align-items:center;gap:10px;font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:600;letter-spacing:.5px;color:var(--cream);text-decoration:none}
header .brand span{color:var(--gold)}
header nav a{color:var(--muted);text-decoration:none;font-size:14px;margin-left:22px}
header nav a:hover{color:var(--cream)}

/* hero */
.hero{position:relative;text-align:center;padding:38px 0 70px}
.gate{position:relative;width:300px;height:300px;margin:6px auto 30px;display:grid;place-items:center}
.ring{position:absolute;border-radius:50%;inset:0}
.ring.r1{border:1px solid var(--line);box-shadow:0 0 60px rgba(230,182,92,.14) inset,0 0 40px rgba(119,78,206,.25)}
.ring.r2{inset:26px;border:1px solid rgba(230,182,92,.35)}
.ring.r3{inset:52px;border:1px dashed rgba(230,182,92,.22)}
.shimmer{position:absolute;inset:-6px;border-radius:50%;
  background:conic-gradient(from 0deg, transparent 0 60%, rgba(230,182,92,.55) 78%, rgba(119,78,206,.5) 88%, transparent 100%);
  -webkit-mask:radial-gradient(farthest-side, transparent calc(100% - 3px), #000 calc(100% - 2px));
          mask:radial-gradient(farthest-side, transparent calc(100% - 3px), #000 calc(100% - 2px));
  animation:spin 18s linear infinite;opacity:.9}
@keyframes spin{to{transform:rotate(360deg)}}
.core{position:relative;width:150px;height:150px;border-radius:50%;display:grid;place-items:center;
  background:radial-gradient(circle at 50% 40%, rgba(119,78,206,.35), rgba(39,31,65,.2) 70%);
  box-shadow:0 0 55px rgba(230,182,92,.25);animation:breathe 6s ease-in-out infinite}
@keyframes breathe{0%,100%{box-shadow:0 0 45px rgba(230,182,92,.18)}50%{box-shadow:0 0 70px rgba(230,182,92,.34)}}
.core img{width:96px;height:auto;filter:drop-shadow(0 0 10px rgba(230,182,92,.45))}

.hero h1{font-family:'Cormorant Garamond',serif;font-weight:600;font-size:clamp(44px,9vw,86px);line-height:1;letter-spacing:.5px;color:var(--cream)}
.hero h1 em{font-style:italic;color:var(--gold)}
.hero .lede{max-width:620px;margin:20px auto 0;font-size:clamp(16px,2.4vw,19px);color:var(--muted)}
.hero .lede em{font-style:italic;color:var(--cream)}
.cta{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;margin-top:30px}
.btn{display:inline-flex;align-items:center;gap:8px;text-decoration:none;font-weight:600;font-size:15px;border-radius:40px;padding:13px 26px;transition:transform .15s,box-shadow .2s}
.btn-gold{background:linear-gradient(180deg,var(--gold),#d7a648);color:#2a1c07;box-shadow:0 8px 26px rgba(230,182,92,.28)}
.btn-gold:hover{transform:translateY(-2px)}
.btn-ghost{border:1px solid var(--line);color:var(--cream)}
.btn-ghost:hover{border-color:var(--gold);color:var(--gold)}

/* sections */
section.band{position:relative;z-index:1;padding:64px 0}
.eyebrow{text-align:center;font-size:12px;font-weight:600;letter-spacing:.28em;text-transform:uppercase;color:var(--gold);margin-bottom:10px}
h2{font-family:'Cormorant Garamond',serif;font-weight:600;font-size:clamp(30px,5vw,44px);text-align:center;letter-spacing:.4px;line-height:1.1}
h2 em{font-style:italic;color:var(--gold)}
.sub{max-width:640px;margin:16px auto 0;text-align:center;color:var(--muted);font-size:17px}
.steps{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-top:40px}
.step{background:var(--card);border:1px solid rgba(255,255,255,.08);border-radius:16px;padding:22px 20px;backdrop-filter:blur(4px)}
.step .n{font-family:'Cormorant Garamond',serif;font-size:30px;color:var(--gold);line-height:1}
.step h3{font-family:'Cormorant Garamond',serif;font-weight:600;font-size:21px;margin:8px 0 6px;color:var(--cream)}
.step p{font-size:14px;color:var(--muted)}

.enter{max-width:720px;margin:0 auto;background:linear-gradient(180deg,rgba(119,78,206,.16),rgba(39,31,65,.25));
  border:1px solid var(--line);border-radius:20px;padding:34px 30px;text-align:center}
.enter h2{font-size:clamp(26px,4vw,36px)}
.enter p{color:var(--muted);margin-top:12px;font-size:16px}
.enter .lock{font-size:13px;color:var(--gold-soft);margin-top:14px;letter-spacing:.02em}

.begin{text-align:center}
.begin .sub a{color:var(--gold);text-decoration:none;border-bottom:1px solid var(--line)}
.begin .sub a:hover{border-color:var(--gold)}

footer{position:relative;z-index:1;text-align:center;padding:46px 24px 60px;border-top:1px solid rgba(255,255,255,.07);margin-top:30px}
footer .mark-tag{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:22px;color:var(--gold)}
footer .fine{color:var(--muted);font-size:13px;margin-top:10px}
footer .fine a{color:var(--muted)}

@media(max-width:760px){.steps{grid-template-columns:1fr 1fr}header nav{display:none}}
@media(max-width:440px){.steps{grid-template-columns:1fr}.gate{width:240px;height:240px}}
@media(prefers-reduced-motion:reduce){*{animation:none!important;scroll-behavior:auto}}
</style>
</head>
<body>
<div class="sky"></div>
<div id="stars" aria-hidden="true"></div>

<header>
  <a class="brand" href="https://glowstrm.com">GlowStrm<span>™</span></a>
  <nav>
    <a href="https://glowstrm.com">Home</a>
    <a href="https://glowstrm.com/self-audit.html">Find your Gap</a>
    <a href="mailto:northnode@glowstrm.com">Contact</a>
  </nav>
</header>

<main>
  <section class="hero wrap">
    <div class="gate" aria-hidden="true">
      <div class="shimmer"></div>
      <div class="ring r1"></div><div class="ring r2"></div><div class="ring r3"></div>
      <div class="core"><img src="data:image/png;base64," alt="GlowStrm"></div>
    </div>
    <h1>The <em>Threshold</em></h1>
    <p class="lede">Every GlowStrm collaboration begins here. Cross the threshold, and you step through to your <em>Stargate</em> — a private world built around your work.</p>
    <div class="cta">
      <a class="btn btn-gold" href="https://glowstrm.com/self-audit.html">Find your gap →</a>
      <a class="btn btn-ghost" href="#how">How it works</a>
    </div>
  </section>

  <section class="band wrap">
    <div class="eyebrow">What this is</div>
    <h2>A private world for <em>every client.</em></h2>
    <p class="sub">Each GlowStrm client receives their own Stargate — a portal into the work we're building together: your strategy, your documents, your tools, and your next steps, all in one calm place. Part of the GlowStrm Planetarium.</p>
  </section>

  <section class="band wrap" id="how">
    <div class="eyebrow">How it works</div>
    <h2>Cross the <em>threshold.</em></h2>
    <div class="steps">
      <div class="step"><div class="n">01</div><h3>We begin</h3><p>A collaboration starts — strategy, clarity, and a plan for what's next.</p></div>
      <div class="step"><div class="n">02</div><h3>You receive your Stargate</h3><p>A private, passcode-protected space, just for you.</p></div>
      <div class="step"><div class="n">03</div><h3>Everything in one place</h3><p>Your Flight Path, your documents, our workshops, and how to reach me.</p></div>
      <div class="step"><div class="n">04</div><h3>Build your world</h3><p>You step through — and we grow it together.</p></div>
    </div>
  </section>

  <section class="band wrap">
    <div class="eyebrow">Inside your Stargate</div>
    <h2>Everything, in <em>one calm place.</em></h2>
    <div class="steps">
      <div class="step"><div class="n">✦</div><h3>Your Cosmogram</h3><p>A guided, step-by-step map through certification and what comes next.</p></div>
      <div class="step"><div class="n">✦</div><h3>The Almanac</h3><p>Your agreements and deliverables, ready to read and download.</p></div>
      <div class="step"><div class="n">✦</div><h3>Waypoints</h3><p>The workshops and events worth your time — with dates and links.</p></div>
      <div class="step"><div class="n">✦</div><h3>Your Signal to North Node</h3><p>Reach me between sessions. No hunting for how to connect.</p></div>
    </div>
  </section>

  <section class="band wrap">
    <div class="enter">
      <h2>Already a <em>client?</em></h2>
      <p>Step through with the private link Sharéa sent you, and bookmark it for next time. Your Stargate is yours alone.</p>
      <div class="lock">🔒 Each Stargate is passcode-protected — your work stays private.</div>
    </div>
  </section>

  <section class="band wrap begin">
    <div class="eyebrow">Not yet?</div>
    <h2>Begin at the <em>source.</em></h2>
    <p class="sub">Start with the free <a href="https://glowstrm.com/self-audit.html">Where's the Gap? Self-Audit</a> to find where your message is breaking down — or <a href="mailto:northnode@glowstrm.com">reach out</a> about working together.</p>
  </section>
</main>

<footer>
  <div class="mark-tag">What grows, glows.</div>
  <div class="fine" style="max-width:660px;margin:12px auto 0;line-height:1.7">
    © 2025–2026 GlowStrm™, LLC. All rights reserved.<br>
    GlowStrm™, Message Architecture™, and Thought Doula™ are trademarks of GlowStrm, LLC. Unauthorized reproduction, distribution, or use of any content, tools, or materials is strictly prohibited.<br>
    Richmond, Virginia · Black woman-owned · <a href="https://glowstrm.com">glowstrm.com</a>
  </div>
</footer>

<script>
// gentle starfield (skipped if reduced motion)
(function(){
  if(matchMedia('(prefers-reduced-motion: reduce)').matches) return;
  const box=document.getElementById('stars'); const n=Math.min(140, Math.round(innerWidth*innerHeight/12000));
  let html='';
  for(let i=0;i<n;i++){
    const s=(Math.random()*2+0.6).toFixed(1);
    const x=(Math.random()*100).toFixed(2), y=(Math.random()*100).toFixed(2);
    const d=(Math.random()*4+2).toFixed(1), delay=(Math.random()*4).toFixed(1);
    html+=`<i class="star" style="width:${s}px;height:${s}px;left:${x}%;top:${y}%;--d:${d}s;animation-delay:${delay}s"></i>`;
  }
  box.innerHTML=html;
})();
</script>
</body>
</html>
