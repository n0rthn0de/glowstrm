<!DOCTYPE html>
<html lang="en">
<head>
<meta name="robots" content="noindex, nofollow">
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Your Cosmogram · Sacred Vibes</title>
<style>
:root{
  color-scheme: light;
  --charcoal:#271F41;
  --charcoal-2:#352a57;
  --gold:#C9A227;
  --gold-soft:#f3e6bf;
  --paper:#faf8f4;
  --card:#ffffff;
  --line:#e7e2d8;
  --ink:#271F41;
  --muted:#6c6680;
  --have:#2e8b57;
  --have-bg:#e7f4ec;
  --prog:#C9A227;
  --prog-bg:#fbf2d6;
  --need:#b54b4b;
  --need-bg:#f9e9e9;
  --focus:#3a3270;
}
*{box-sizing:border-box}
html{scroll-behavior:smooth}
body{
  margin:0;background:var(--paper);color:var(--ink);
  font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;
  line-height:1.5;font-size:16px;
}
.wrap{max-width:900px;margin:0 auto;padding:0 18px 90px}

/* ---------- HERO ---------- */
.hero{background:var(--charcoal);color:#fff;border-radius:0 0 20px 20px;margin:0 -18px 20px;padding:24px 26px 22px;display:flex;flex-wrap:wrap;align-items:center;gap:20px;justify-content:space-between}
.hero img{height:46px;width:auto;display:block}
.hero .htext{flex:1;min-width:230px}
.hero .tagline{color:var(--gold);font-weight:700;font-size:11px;text-transform:uppercase;letter-spacing:2px}
.hero h1{font-size:21px;margin:6px 0 3px;letter-spacing:.2px;font-weight:800}
.hero .sub{color:#d9d3ea;font-size:12.5px}
.ring{display:flex;align-items:center;gap:12px;background:var(--charcoal-2);border:1px solid #4a3f74;border-radius:14px;padding:12px 15px}
.ring svg{transform:rotate(-90deg)}
.ring .rtext .pnum{font-size:22px;font-weight:800;line-height:1}
.ring .rtext .plabel{font-size:11px;color:var(--gold-soft)}

/* ---------- WELCOME STRIP ---------- */
.welcome{display:flex;flex-wrap:wrap;align-items:center;gap:10px;justify-content:space-between;background:#fff;border:1px solid var(--line);border-radius:12px;padding:11px 15px;margin-bottom:16px;font-size:13px;color:var(--muted)}
.welcome b{color:var(--ink)}
.welcome .settings{display:flex;gap:8px;flex-wrap:wrap}
.mini{border:1px solid var(--line);background:#fff;border-radius:18px;padding:6px 12px;font-size:12.5px;cursor:pointer;color:var(--ink)}
.mini:hover{background:#faf8f4}

/* ---------- NEXT STEP ---------- */
.nextstep{background:linear-gradient(135deg,#2f2658,#3a3270);color:#fff;border-radius:16px;padding:20px 22px;margin-bottom:18px;box-shadow:0 8px 24px rgba(39,31,65,.14)}
.nextstep .eyebrow{font-size:11px;font-weight:700;letter-spacing:1.6px;text-transform:uppercase;color:var(--gold)}
.nextstep h2{margin:6px 0 4px;font-size:19px;line-height:1.3}
.nextstep .ns-desc{font-size:13.5px;color:#e5e1f2;margin-bottom:4px}
.nextstep .ns-tip{font-size:12.5px;color:#c9c2e6;margin-top:6px}
.nextstep .ns-actions{display:flex;flex-wrap:wrap;gap:10px;margin-top:14px}
.btn{border:none;border-radius:10px;padding:11px 18px;font-size:14px;font-weight:700;cursor:pointer;text-decoration:none;display:inline-flex;align-items:center;gap:7px}
.btn-gold{background:var(--gold);color:#271515}
.btn-gold:hover{filter:brightness(1.05)}
.btn-ghost{background:rgba(255,255,255,.12);color:#fff;border:1px solid rgba(255,255,255,.3)}
.btn-ghost:hover{background:rgba(255,255,255,.2)}
.nextstep.done{background:linear-gradient(135deg,#236b45,#2e8b57)}
.nextstep.done .eyebrow{color:#d6f0e0}

/* ---------- CONTROLS ---------- */
.controls{display:flex;gap:10px;flex-wrap:wrap;align-items:center;margin:6px 0 18px}
.toggle{display:inline-flex;align-items:center;gap:9px;background:#fff;border:1px solid var(--line);border-radius:22px;padding:8px 14px;font-size:13.5px;cursor:pointer;user-select:none}
.toggle .sw{width:34px;height:20px;border-radius:12px;background:#d8d3c6;position:relative;transition:background .2s;flex:none}
.toggle .sw::after{content:"";position:absolute;top:2px;left:2px;width:16px;height:16px;border-radius:50%;background:#fff;transition:left .2s;box-shadow:0 1px 2px rgba(0,0,0,.2)}
.toggle.on .sw{background:var(--gold)}
.toggle.on .sw::after{left:16px}
.controls .spacer{flex:1}
.controls .lnk{border:1px solid var(--line);background:#fff;border-radius:20px;padding:8px 14px;font-size:13px;cursor:pointer;color:var(--ink);text-decoration:none}
.controls .lnk.reset{color:var(--need);border-color:#e6cccc}

/* ---------- SECTIONS ---------- */
.legend{display:flex;gap:16px;flex-wrap:wrap;margin:0 0 14px;font-size:12.5px;color:var(--muted)}
.dot{display:inline-block;width:10px;height:10px;border-radius:50%;margin-right:5px;vertical-align:middle}
.dot.have{background:var(--have)} .dot.prog{background:var(--prog)} .dot.need{background:var(--need)}

.track{background:var(--card);border:1px solid var(--line);border-radius:14px;margin-bottom:16px;overflow:hidden}
.track.complete{border-color:#bfe0cd;background:#fbfefc}
.thead{margin:0;font-size:15.5px;padding:15px 18px;background:linear-gradient(180deg,#fff,#fbfaf7);border-bottom:1px solid var(--line);display:flex;align-items:center;gap:11px;cursor:pointer;user-select:none}
.track.collapsed .thead{border-bottom:none}
.thead .num{display:inline-flex;width:26px;height:26px;border-radius:50%;background:var(--charcoal);color:#fff;align-items:center;justify-content:center;font-size:13px;flex:none;font-weight:700}
.track.complete .thead .num{background:var(--have)}
.thead .ttitle{font-weight:700}
.thead .tprog{margin-left:auto;font-size:12px;font-weight:600;color:var(--muted);white-space:nowrap}
.thead .chev{transition:transform .2s;color:var(--muted);font-size:13px}
.track.collapsed .thead .chev{transform:rotate(-90deg)}
.tbody{display:block}
.track.collapsed .tbody{display:none}
.tinner{display:flex;align-items:stretch}
.titems{flex:1;min-width:0}
.trail{width:238px;flex:none;border-left:1px solid var(--line);background:#fbfaf7;padding:14px 15px}
.trail h4{margin:0 0 3px;font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:.7px;color:var(--muted)}
.trail .thint{font-size:11px;color:#9a94ac;margin-bottom:10px}
.trail a{display:flex;align-items:flex-start;gap:7px;text-decoration:none;font-size:12.3px;font-weight:600;color:var(--ink);border:1px solid var(--line);background:#fff;border-radius:8px;padding:7px 9px;margin-bottom:7px;line-height:1.3}
.trail a:hover{border-color:var(--gold)}
.trail a.doc{background:var(--have-bg);border-color:#cfe6d9;color:#1f6b41}
.trail a small{display:block;font-weight:400;color:var(--muted);font-size:10.5px;margin-top:1px}
.trail .slide{font-size:10.5px;color:#9a94ac;font-style:italic;margin-top:4px}
@media(max-width:720px){.tinner{flex-direction:column}.trail{width:auto;border-left:none;border-top:1px solid var(--line)}}

.item{display:grid;grid-template-columns:118px 1fr;gap:14px;padding:15px 18px;border-bottom:1px solid #f1ede4}
.item:last-child{border-bottom:none}
.item.hide{display:none}
.statusbtn{border:none;border-radius:10px;padding:10px 6px;font-size:12px;font-weight:800;cursor:pointer;text-align:center;height:fit-content;letter-spacing:.3px;min-height:52px}
.statusbtn small{display:block;font-weight:500;font-size:10px;opacity:.85;margin-top:3px}
.s-have{background:var(--have-bg);color:var(--have);box-shadow:inset 0 0 0 1px #bfe0cd}
.s-prog{background:var(--prog-bg);color:#9a7d12;box-shadow:inset 0 0 0 1px #ecd9a0}
.s-need{background:var(--need-bg);color:var(--need);box-shadow:inset 0 0 0 1px #e6c4c4}
.body .label{font-weight:700;font-size:15px}
.body .desc{font-size:13px;color:#54506a;margin-top:4px}
.body .tip{font-size:12.5px;color:#8a6d10;background:#fdf8e9;border-radius:8px;padding:6px 10px;margin-top:8px;display:inline-block}
.body .src{font-size:11.5px;color:#9a94ac;margin-top:7px;font-style:italic}
.body .src b{font-style:normal;color:#6c6680}
.links{margin-top:9px;display:flex;flex-wrap:wrap;gap:8px}
.links a{font-size:12px;text-decoration:none;border-radius:8px;padding:7px 11px;font-weight:600;border:1px solid var(--line);display:inline-flex;align-items:center;gap:5px}
.links a.portal{background:#eef0fb;color:#3a3270;border-color:#d6d8ef}
.links a.doc{background:var(--have-bg);color:#1f6b41;border-color:#bfe0cd}
.links a:hover{filter:brightness(.98)}
.note{margin-top:9px;width:100%;border:1px solid var(--line);border-radius:9px;padding:8px 10px;font-size:13px;font-family:inherit;resize:vertical;min-height:36px;background:#fffdf9}
.note::placeholder{color:#b3aec2}

/* ---------- NIGP CODE CARD ---------- */
.codes{margin-top:10px;background:#fbfaff;border:1px solid #e0dcf0;border-radius:10px;padding:12px 13px}
.codes h4{margin:0 0 3px;font-size:13px;color:var(--charcoal)}
.codes .chint{font-size:11.5px;color:var(--muted);margin-bottom:9px}
.coderow{display:flex;align-items:center;gap:10px;padding:8px 0;border-top:1px dashed #e4e0f0}
.coderow:first-of-type{border-top:none}
.codepill{font-weight:800;font-size:13px;color:#3a3270;background:#eef0fb;border:1px solid #d6d8ef;border-radius:7px;padding:5px 9px;white-space:nowrap;font-variant-numeric:tabular-nums}
.codedesc{flex:1;font-size:12.5px}
.codedesc b{display:block;font-size:12.5px;color:var(--ink)}
.codedesc span{color:var(--muted);font-size:11.5px}
.copybtn{border:1px solid var(--line);background:#fff;border-radius:7px;padding:6px 10px;font-size:11.5px;cursor:pointer;white-space:nowrap;font-weight:600}
.copybtn.copied{background:var(--have-bg);color:#1f6b41;border-color:#bfe0cd}
.opt{font-size:10px;font-weight:700;color:#8a6d10;background:var(--gold-soft);border-radius:5px;padding:1px 6px;margin-left:6px;vertical-align:middle;text-transform:uppercase;letter-spacing:.4px}

/* ---------- INFO CARDS ---------- */
.info{background:#fff;border:1px solid #d6d2e2;border-left:5px solid var(--charcoal);border-radius:12px;padding:15px 17px;margin-bottom:18px}
.info h3{margin:0 0 8px;font-size:14.5px;color:var(--charcoal)}
.info li{font-size:12.8px;margin-bottom:6px;color:#5c5470}
.info.gold{border-left-color:var(--gold);border-color:#ecd9a0}
.info.gold h3{color:#8a6d10}

.res{background:var(--card);border:1px solid var(--line);border-radius:14px;padding:16px 18px;margin-bottom:18px}
.res h3{margin:0 0 4px;font-size:15.5px}
.res .rhint{font-size:12.5px;color:var(--muted);margin-bottom:12px}
.resgrid{display:grid;grid-template-columns:1fr 1fr;gap:9px}
.resgrid a{display:flex;align-items:center;gap:9px;text-decoration:none;border:1px solid var(--line);border-radius:10px;padding:11px 12px;font-size:13px;font-weight:600;color:var(--ink);background:#fffdf9}
.resgrid a:hover{border-color:var(--gold);background:#fefcf5}
.resgrid a .ic{font-size:16px}
.resgrid a small{display:block;font-weight:400;color:var(--muted);font-size:11px;margin-top:1px}
.rsub{font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:var(--muted);margin:14px 0 8px}

.foot{text-align:center;color:var(--muted);font-size:11.5px;margin-top:22px;line-height:1.7}
.foot b{color:var(--charcoal)}

.saved{position:fixed;bottom:18px;right:18px;background:var(--charcoal);color:#fff;padding:10px 17px;border-radius:22px;font-size:13px;opacity:0;transform:translateY(8px);transition:opacity .3s,transform .3s;pointer-events:none;z-index:30}
.saved.show{opacity:1;transform:translateY(0)}

/* ---------- LOCK ---------- */
.lockscreen{position:fixed;inset:0;background:var(--charcoal);color:#fff;display:none;align-items:center;justify-content:center;z-index:50;padding:20px}
.lockscreen.show{display:flex}
.lockbox{max-width:360px;width:100%;text-align:center}
.lockbox img{height:44px;margin-bottom:18px}
.lockbox h2{margin:0 0 6px;font-size:20px}
.lockbox p{color:#cfc8e6;font-size:13.5px;margin:0 0 18px}
.lockbox input{width:100%;border:1px solid #4a3f74;background:#352a57;color:#fff;border-radius:11px;padding:13px 14px;font-size:16px;text-align:center;letter-spacing:3px;margin-bottom:12px}
.lockbox input::placeholder{color:#8a82ad;letter-spacing:normal}
.lockbox .lbtn{width:100%;background:var(--gold);color:#271515;border:none;border-radius:11px;padding:13px;font-size:15px;font-weight:800;cursor:pointer}
.lockbox .remember{display:flex;align-items:center;justify-content:center;gap:8px;font-size:12.5px;color:#cfc8e6;margin:10px 0 0;cursor:pointer}
.lockbox .msg{font-size:12.5px;color:#f0b8b8;min-height:18px;margin-top:10px}
.lockbox .forgot{font-size:11.5px;color:#8a82ad;margin-top:16px}
.lockbox .forgot a{color:#b7afd6}

@media(prefers-reduced-motion: reduce){*{transition:none!important;animation:none!important}html{scroll-behavior:auto}}
@media(max-width:640px){
  .item{grid-template-columns:1fr}
  .statusbtn{min-height:0}
  .resgrid{grid-template-columns:1fr}
  .hero h1{font-size:19px}
}
@media print{.controls,.saved,.welcome .settings,.lockscreen,.thead .chev{display:none}.track.collapsed .tbody{display:block}.hero{border-radius:0}body{background:#fff}}
</style>
</head>
<body>

<!-- LOCK SCREEN -->
<div class="lockscreen" id="lockscreen">
  <div class="lockbox">
    <img src="data:image/png;base64," alt="GlowStrm">
