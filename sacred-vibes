/* ============ STATE ============ */
const STATES = ["need","prog","have"];
const LABELS = {need:"NOT<br>STARTED", prog:"IN<br>PROGRESS", have:"DONE ✓"};
const SUBS = {need:"tap to start", prog:"tap when done", have:"nice work"};
const KEY = "sacredvibes_swam_v2";
const REMEMBER_KEY = "sacredvibes_swam_remember";
const SETUP = {structure:"single-llc", desig:["small","micro","woman","minority"], franchise:false};

let store = JSON.parse(localStorage.getItem(KEY) || "{}");
function allItems(){ return DATA.flatMap(t=>t.items); }
function defaults(){ const d={}; allItems().forEach(i=>d[i.id]={status:i.def,note:i.note||""}); return d; }
function ensure(){
  if(!store.items) store.items = defaults();
  const d=defaults(); for(const k in d){ if(!store.items[k]) store.items[k]=d[k]; }
  if(!store.setup) store.setup = JSON.parse(JSON.stringify(SETUP));
  if(!store.ui) store.ui = {focus:true, collapsed:{}};
  if(!store.lock) store.lock = {enabled:false, code:null};
}
ensure();

function save(msg){
  store.ui.lastVisit = Date.now();
  localStorage.setItem(KEY, JSON.stringify(store));
  const s=document.getElementById('saved'); s.textContent = msg||"Saved ✓ — I'll remember this"; s.classList.add('show');
  clearTimeout(window._st); window._st=setTimeout(()=>s.classList.remove('show'),1100);
}
function applies(i){
  const s=store.setup;
  if(i.entity && !i.entity.includes(s.structure)) return false;
  if(i.desig && !i.desig.some(d=>s.desig.includes(d))) return false;
  if(i.franchise && !s.franchise) return false;
  return true;
}
function esc(s){ return (s||"").replace(/</g,"&lt;"); }

/* ============ NEXT STEP ============ */
function firstOutstanding(){
  for(const t of DATA){ for(const i of t.items){ if(applies(i) && store.items[i.id].status!=="have") return {t,i}; } }
  return null;
}
function renderNextStep(){
  const el=document.getElementById('nextstep');
  const n=firstOutstanding();
  if(!n){
    el.className="nextstep done";
    el.innerHTML=`<div class="eyebrow">You did it 🎉</div><h2>Every step is done.</h2><div class="ns-desc">Sacred Vibes is fully prepped for eVA and SWaM. If you submitted, watch your email — SBSD replies within ~60 business days.</div>`;
    return;
  }
  el.className="nextstep";
  const st=store.items[n.i.id].status;
  const link=(n.i.links&&n.i.links[0])?`<a class="btn btn-gold" href="${n.i.links[0].href}" target="_blank" rel="noopener">${n.i.links[0].label} →</a>`:'';
  el.innerHTML=`<div class="eyebrow">Your next step · ${n.t.track}</div>
    <h2>${n.i.label.replace(/<br>/g,' ')}</h2>
    <div class="ns-desc">${n.i.desc}</div>
    ${n.i.tip?`<div class="ns-tip">${n.i.tip}</div>`:''}
    <div class="ns-actions">
      ${link}
      <button class="btn btn-ghost" data-advance="${n.i.id}">${st==="need"?"Mark as in progress":"Mark as done ✓"}</button>
    </div>`;
  el.querySelector('[data-advance]').onclick=()=>{
    const id=n.i.id; store.items[id].status = STATES[Math.min(STATES.indexOf(store.items[id].status)+1,2)];
    save(); renderAll();
  };
}

/* ============ TRACKS ============ */
function renderTracks(){
  const root=document.getElementById('tracks'); root.innerHTML="";
  const focus=store.ui.focus;
  DATA.forEach(t=>{
    const items=t.items.filter(applies);
    if(items.length===0) return;
    const have=items.filter(i=>store.items[i.id].status==="have").length;
    const complete=have===items.length;
    if(focus && complete) return; // in focus mode, hide finished sections entirely
    const shown = focus ? items.filter(i=>store.items[i.id].status!=="have") : items;
    if(shown.length===0) return;
    if(store.ui.collapsed[t.num]===undefined) store.ui.collapsed[t.num]=complete;
    const collapsed=store.ui.collapsed[t.num] && !focus;
    const sec=document.createElement('div');
    sec.className="track"+(complete?" complete":"")+(collapsed?" collapsed":"");
    let html=`<div class="thead" data-toggle="${t.num}"><span class="num">${complete?'✓':t.num}</span><span class="ttitle">${t.track}</span><span class="tprog">${have}/${items.length} done</span><span class="chev">▾</span></div><div class="tbody"><div class="tinner"><div class="titems">`;
    shown.forEach(i=>{
      const s=store.items[i.id].status;
      const links=(i.links||[]).map(l=>`<a class="${l.type==='doc'?'doc':'portal'}" href="${l.href}" target="_blank" rel="noopener">${l.type==='doc'?'📄':'🔗'} ${l.label}</a>`).join('');
      let codes="";
      if(i.codes){
        codes=`<div class="codes"><h4>Recommended codes for Sacred Vibes</h4><div class="chint">Add these in eVA. Optional ones widen your reach — start with the top four.</div>`;
        i.codes.forEach(c=>{ codes+=`<div class="coderow"><span class="codepill">${c.code}</span><div class="codedesc"><b>${c.name}${c.opt?'<span class="opt">optional</span>':''}</b><span>${c.use}</span></div><button class="copybtn" data-copy="${c.code}">Copy</button></div>`; });
        codes+=`</div>`;
      }
      html+=`<div class="item">
        <button class="statusbtn s-${s}" data-id="${i.id}">${LABELS[s]}<small>${SUBS[s]}</small></button>
        <div class="body">
          <div class="label">${i.label}</div>
          <div class="desc">${i.desc}</div>
          ${i.tip?`<div class="tip">${i.tip}</div>`:''}
          ${codes}
          <div class="src">${i.src}</div>
          ${links?`<div class="links">${links}</div>`:''}
          <textarea class="note" data-note="${i.id}" placeholder="Jot a note, paste a link, or say where this lives…">${esc(store.items[i.id].note)}</textarea>
        </div></div>`;
    });
    html+=`</div>`; // close titems
    if(t.resources && t.resources.length){
      html+=`<div class="trail"><h4>For this step</h4><div class="thint">Sources, links &amp; docs</div>`;
      t.resources.forEach(r=>{ html+=`<a class="${r.type==='doc'?'doc':''}" href="${r.href}" target="_blank" rel="noopener"><span>${r.type==='doc'?'📄':'🔗'}</span><span>${r.label}${r.sub?`<small>${r.sub}</small>`:''}</span></a>`; });
      if(t.railslide) html+=`<div class="slide">📖 ${t.railslide}</div>`;
      html+=`</div>`;
    }
    html+=`</div></div>`; // close tinner + tbody
    sec.innerHTML=html; root.appendChild(sec);
  });
  bindTracks();
}
function bindTracks(){
  document.querySelectorAll('.statusbtn').forEach(b=>b.onclick=()=>{
    const id=b.dataset.id; store.items[id].status=STATES[(STATES.indexOf(store.items[id].status)+1)%3]; save(); renderAll();
  });
  document.querySelectorAll('[data-note]').forEach(t=>t.onchange=()=>{ store.items[t.dataset.note].note=t.value; save(); });
  document.querySelectorAll('[data-toggle]').forEach(h=>h.onclick=()=>{
    if(store.ui.focus) return; const n=h.dataset.toggle; store.ui.collapsed[n]=!store.ui.collapsed[n]; save("Saved ✓"); renderTracks();
  });
  document.querySelectorAll('[data-copy]').forEach(b=>b.onclick=async()=>{
    const code=b.dataset.copy;
    try{ await navigator.clipboard.writeText(code); }catch(e){ const ta=document.createElement('textarea'); ta.value=code; document.body.appendChild(ta); ta.select(); document.execCommand('copy'); ta.remove(); }
    b.textContent="Copied ✓"; b.classList.add('copied'); setTimeout(()=>{ b.textContent="Copy"; b.classList.remove('copied'); },1400);
  });
}

/* ============ TOTALS + WELCOME ============ */
function renderTotals(){
  const items=allItems().filter(applies);
  let total=items.length, score=0, haveN=0;
  items.forEach(i=>{ const s=store.items[i.id].status; score+= s==="have"?1 : s==="prog"?0.5:0; if(s==="have")haveN++; });
  const pct= total? Math.round(score/total*100):0;
  document.getElementById('pnum').textContent=pct+"%";
  const circ=157, off=circ-(circ*pct/100);
  document.getElementById('ringfill').style.strokeDashoffset=off;
  const w=document.getElementById('welcometext');
  const last=store.ui.lastVisit;
  const when = last? new Date(last).toLocaleDateString(undefined,{month:'short',day:'numeric'}) : null;
  if(pct===0) w.innerHTML="Take it one step at a time — I'll save everything as you go.";
  else if(pct===100) w.innerHTML="<b>All done.</b> Everything's saved here whenever you want to look back.";
  else w.innerHTML=`<b>${haveN} of ${total} done.</b> ${when?`Last here ${when}. `:''}Pick up right where you left off.`;
}

function renderAll(){ renderNextStep(); renderTracks(); renderTotals(); }

/* ============ CONTROLS ============ */
document.getElementById('focusToggle').onclick=function(){
  store.ui.focus=!store.ui.focus; this.classList.toggle('on',store.ui.focus);
  this.querySelector('span:last-child').textContent = store.ui.focus? "Focus mode — show only what's next" : "Showing everything";
  save("Saved ✓"); renderAll();
};
document.getElementById('printbtn').onclick=()=>window.print();
document.getElementById('reset').onclick=()=>{
  if(confirm("Reset every status back to 'Not started'? Your notes stay, and this can't be undone.")){
    allItems().forEach(i=>store.items[i.id].status=i.def); save("Reset ✓"); renderAll();
  }
};

/* ============ PRIVATE LOCK ============ */
function hash(s){ let h=0; for(let i=0;i<s.length;i++){ h=(h<<5)-h+s.charCodeAt(i); h|=0; } return String(h); }
const lockscreen=document.getElementById('lockscreen');
function showLock(){
  lockscreen.classList.add('show');
  document.getElementById('lockforgot').innerHTML = 'Forgot it? You can <a href="#" id="clearlock">reset this space</a> (clears your saved progress).';
  document.getElementById('clearlock').onclick=(e)=>{ e.preventDefault(); if(confirm("This clears your passcode AND your saved progress on this device. Continue?")){ localStorage.removeItem(KEY); localStorage.removeItem(REMEMBER_KEY); location.reload(); } };
  setTimeout(()=>document.getElementById('lockinput').focus(),100);
}
function tryUnlock(){
  const val=document.getElementById('lockinput').value.trim();
  const msg=document.getElementById('lockmsg');
  if(hash(val)===store.lock.code){
    if(document.getElementById('lockremember').checked) localStorage.setItem(REMEMBER_KEY, store.lock.code);
    lockscreen.classList.remove('show');
  } else { msg.textContent="That doesn't match — try again."; document.getElementById('lockinput').value=""; document.getElementById('lockinput').focus(); }
}
document.getElementById('lockbtn').onclick=tryUnlock;
document.getElementById('lockinput').addEventListener('keydown',e=>{ if(e.key==='Enter') tryUnlock(); });

document.getElementById('privatebtn').onclick=()=>{
  if(store.lock.enabled){
    if(confirm("Remove the passcode lock from this space?")){ store.lock={enabled:false,code:null}; localStorage.removeItem(REMEMBER_KEY); save("Lock removed"); updatePrivateBtn(); }
    return;
  }
  const code=prompt("Set a passcode just for you (numbers or letters). You'll enter it when you come back:");
  if(code && code.trim().length>=3){
    store.lock={enabled:true, code:hash(code.trim())};
    localStorage.setItem(REMEMBER_KEY, store.lock.code); // remember on this device now
    save("This space is now private 🔒"); updatePrivateBtn();
    alert("Done — this space is now private. Tip: it's a light lock for shared devices, not bank-level security. If you ever forget it, you can reset from the unlock screen.");
  } else if(code!==null){ alert("Let's use at least 3 characters."); }
};
function updatePrivateBtn(){ document.getElementById('privatebtn').textContent = store.lock.enabled? "🔓 Private (tap to remove)" : "🔒 Make private"; }

/* gate on load */
if(store.lock.enabled){
  const remembered = localStorage.getItem(REMEMBER_KEY);
  if(remembered!==store.lock.code) showLock();
}
updatePrivateBtn();

/* business structure picker */
const structureSel=document.getElementById('structureSel');
structureSel.value=store.setup.structure;
structureSel.onchange=()=>{ store.setup.structure=structureSel.value; save("Saved ✓"); renderAll(); };

renderAll();
</script>
</body>
</html>
