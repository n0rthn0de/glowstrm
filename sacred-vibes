    <input type="password" id="lockinput" inputmode="numeric" placeholder="Your passcode" autocomplete="off">
    <button class="lbtn" id="lockbtn">Unlock</button>
    <label class="remember"><input type="checkbox" id="lockremember" checked> Remember me on this device</label>
