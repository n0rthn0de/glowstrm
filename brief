  .hero-content { max-width: 860px; margin: 0 auto; }
  .eyebrow { font-family: 'Source Sans 3', sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 0.22em; text-transform: uppercase; color: var(--rose); margin-bottom: 20px; display: flex; align-items: center; gap: 10px; }
