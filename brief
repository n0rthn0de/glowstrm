  .hero-who { font-size: 14px; font-weight: 300; color: var(--muted); max-width: 560px; line-height: 1.7; margin-bottom: 32px; }
  .meta-row { display: flex; flex-wrap: wrap; gap: 24px; margin-bottom: 8px; }
  .meta-item { font-size: 13px; font-weight: 400; color: var(--muted); letter-spacing: 0.06em; text-transform: uppercase; display: flex; align-items: center; gap: 8px; }
  .meta-item::before { content: ''; display: inline-block; width: 4px; height: 4px; border-radius: 50%; background: var(--coral); flex-shrink: 0; }
  .founding-bar { font-size: 13px; font-weight: 300; color: var(--gold); line-height: 1.6; margin-top: 16px; margin-bottom: 28px; padding: 12px 16px; border-left: 2px solid var(--gold); background: rgba(230,182,92,0.06); max-width: 580px; }
  .btn { display: inline-flex; align-items: center; font-family: 'Source Sans 3', sans-serif; font-size: 13px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; padding: 15px 36px; border: none; cursor: pointer; text-decoration: none; transition: all 0.25s ease; min-height: 52px; }
  .btn-gold { background: var(--gold); color: var(--dark); }
  .btn-gold:hover { background: #edc46a; transform: translateY(-1px); }
  .btn-ghost { background: transparent; color: var(--muted); border: 1px solid var(--border); }
  .btn-ghost:hover { border-color: var(--border-hi); color: var(--cream); }
  .btn-group { display: flex; gap: 12px; flex-wrap: wrap; }

  /* ── SECTION LABELS ── */
  .sec-eye { font-family: 'Source Sans 3', sans-serif; font-size: 10px; font-weight: 700; letter-spacing: 0.22em; text-transform: uppercase; color: var(--violet); margin-bottom: 20px; }
