  .cta-band h2 em { font-style: italic; color: var(--rose); }
  .cta-detail { font-size: 13px; font-weight: 300; color: var(--muted); line-height: 1.6; }
  .cta-detail a { color: var(--gold); text-decoration: none; }

  /* ── FOOTER ── */
  footer { padding: 28px clamp(24px, 6vw, 80px); border-top: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px; }
  .footer-note { font-size: 11px; font-weight: 300; color: var(--border-hi); letter-spacing: 0.04em; line-height: 1.8; }
