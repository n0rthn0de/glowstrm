  .price-right { flex: 1; border-left: 1px solid var(--border); padding-left: 22px; }
  .price-right-lbl { font-size: 9px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--violet); margin-bottom: 12px; }
  .price-feat { font-size: 13px; font-weight: 300; color: var(--cream); padding: 4px 0 4px 10px; border-left: 2px solid var(--border-hi); margin-bottom: 4px; line-height: 1.4; }

  /* ── CTA BAND ── */
  .cta-band { background: var(--surface); border-top: 1px solid var(--border); padding: clamp(52px, 8vw, 80px) clamp(24px, 6vw, 80px); }
