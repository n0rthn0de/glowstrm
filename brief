  .price-eye { font-size: 9px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--rose); margin-bottom: 8px; }
  .price-num { font-family: 'Cormorant Garamond', serif; font-size: 52px; font-weight: 300; color: var(--cream); line-height: 1; margin-bottom: 8px; }
  .price-note { font-size: 12px; color: var(--muted); font-style: italic; line-height: 1.65; }
