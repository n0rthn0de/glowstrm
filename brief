  .del-tier.foundation { color: var(--violet); }
  .del-tier.execution  { color: var(--muted); margin-top: 8px; }
  .del-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 0; }
  .del-item { display: flex; gap: 12px; padding: 14px 13px; background: rgba(255,255,255,0.03); border-top: 2px solid var(--rose); }
  .del-item.f { border-top-color: var(--violet); background: rgba(119,78,206,0.06); }
  .del-item.f:nth-child(2) { border-top-color: var(--plum); }
  .del-item.f:nth-child(3) { border-top-color: var(--rose); }
  .del-item.e:nth-child(2) { border-top-color: var(--gold); }
  .del-item.e:nth-child(3) { border-top-color: var(--coral); }
  .del-item.e:nth-child(4) { border-top-color: var(--rose); grid-column: 1 / -1; background: rgba(255,255,255,0.02); }
  .del-n { font-family: 'Cormorant Garamond', serif; font-size: 20px; font-weight: 300; color: rgba(255,255,255,0.12); line-height: 1; flex-shrink: 0; min-width: 24px; padding-top: 1px; }
  .del-n.f { color: rgba(119,78,206,0.45); }
  .del-title { font-size: 12px; font-weight: 600; color: var(--cream); margin-bottom: 3px; }
  .del-body  { font-size: 12px; font-weight: 300; color: var(--muted); line-height: 1.55; }

  /* ── PRICING ── */
  .pricing-box { display: flex; gap: 24px; margin-top: 24px; padding: 24px 22px; border: 1px solid var(--border); border-top: 3px solid var(--rose); background: rgba(187,64,114,0.04); }
