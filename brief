  /* ── BLUEPRINT TWO-COL ── */
  .bp-cols { display: grid; grid-template-columns: 1fr 1fr; gap: 2px; margin-top: 28px; }
  .bp-col { padding: 24px 22px; }
  .bp-col.without { background: rgba(255,255,255,0.03); border-top: 3px solid rgba(255,255,255,0.12); }
  .bp-col.with    { background: rgba(119,78,206,0.08); border-top: 3px solid var(--violet); }
  .bp-lbl { font-size: 9px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; margin-bottom: 8px; }
  .bp-col.without .bp-lbl { color: rgba(255,255,255,0.3); }
  .bp-col.with .bp-lbl    { color: var(--violet); }
  .bp-col h3 { font-family: 'Cormorant Garamond', serif; font-size: 18px; font-weight: 400; color: var(--cream); margin-bottom: 8px; line-height: 1.3; }
  .bp-col p  { font-size: 14px; color: var(--muted); line-height: 1.7; }

  /* ── PULL QUOTE ── */
  .pull-quote { border-left: 3px solid var(--rose); background: rgba(187,64,114,0.06); padding: 24px 28px; margin-top: 32px; }
  .pull-quote blockquote { font-family: 'Cormorant Garamond', serif; font-size: clamp(18px, 2.5vw, 23px); font-style: italic; font-weight: 300; color: var(--cream); line-height: 1.5; margin-bottom: 10px; }
  .pull-quote cite { font-size: 9.5px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--rose); font-style: normal; display: block; }

  /* ── COMPARE TABLE ── */
  .compare { width: 100%; border-collapse: collapse; margin-top: 28px; }
  .compare th { font-size: 9px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; padding: 10px 14px; text-align: left; }
  .th-no  { background: rgba(255,255,255,0.04); color: var(--muted); border-right: 1px solid var(--border); width: 50%; }
  .th-yes { background: var(--violet); color: #fff; width: 50%; }
  .compare td { padding: 11px 14px; font-size: 14px; font-weight: 300; vertical-align: top; line-height: 1.6; }
  .compare tr:nth-child(even) .td-no  { background: rgba(255,255,255,0.02); }
  .compare tr:nth-child(even) .td-yes { background: rgba(119,78,206,0.08); }
  .td-no  { color: var(--muted); border-right: 1px solid var(--border); }
  .td-yes { color: var(--cream); }

  /* ── SOUNDS LIKE YOU ── */
  .sl-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-top: 20px; margin-bottom: 24px; }
  .sl-item { font-size: 14px; font-weight: 300; color: var(--cream); padding: 12px 14px 12px 20px; background: rgba(255,255,255,0.03); border-left: 2px solid var(--rose); line-height: 1.6; }

