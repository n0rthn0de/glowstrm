<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="theme-color" content="#271F41" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <title>GlowStrm, LLC — Message Architecture</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Source+Sans+3:ital,wght@0,300;0,400;0,600;1,300&display=swap" rel="stylesheet" />

  <style>
    /* ════════════════════════════════════════════
       DESIGN TOKENS — GlowStrm Brand Identity 2026
    ════════════════════════════════════════════ */
    :root {
      --charcoal:  #271F41;
      --dark:      #2B2E3A;
      --surface:   #211a36;
      --cream:     #F5F2EC;
      --cream-dim: #9C96AE;
      --rule:      #362d52;
      --rule-hi:   #453b62;
      --rose:      #BB4072;
      --plum:      #783E8D;
      --violet:    #774ECE;
      --coral:     #FB896D;
      --gold:      #E6B65C;
      --f-display: 'Cormorant Garamond', Georgia, serif;
      --f-body:    'Source Sans 3', Arial, sans-serif;
      --max-w:     880px;
      --pad-x:     clamp(1.25rem, 5vw, 2.5rem);
      --safe-top:    env(safe-area-inset-top, 0px);
      --safe-bottom: env(safe-area-inset-bottom, 0px);
      --sticky-cta-h: 72px;
    }

    /* ════════════════════════════════════════════
       RESET
    ════════════════════════════════════════════ */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      background: var(--charcoal);
      color: var(--cream);
      font-family: var(--f-body);
      font-size: 16px;
      line-height: 1.6;
      font-weight: 400;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }
    img, svg { display: block; max-width: 100%; }

    /* ════════════════════════════════════════════
       ANIMATIONS
    ════════════════════════════════════════════ */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes ticker {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }
    .fade-up { animation: fadeUp 0.85s cubic-bezier(0.22,1,0.36,1) both; }
    .d1 { animation-delay: 0.1s; }
    .d2 { animation-delay: 0.28s; }
    .d3 { animation-delay: 0.46s; }
    .d4 { animation-delay: 0.62s; }

    /* ════════════════════════════════════════════
       LAYOUT
    ════════════════════════════════════════════ */
    .container {
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 0 var(--pad-x);
    }
    .gradient-bar {
      height: 3px;
      background: linear-gradient(90deg, var(--rose), var(--plum), var(--violet), var(--coral), var(--gold));
      flex-shrink: 0;
    }
    hr.rule { border: none; border-top: 1px solid var(--rule); }

    /* ════════════════════════════════════════════
       NAV
    ════════════════════════════════════════════ */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 200;
      background: rgba(39,31,65,0.94);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
      border-bottom: 1px solid var(--rule);
    }
    .nav-inner {
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 0 var(--pad-x);
      height: 60px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .nav-logo {
      font-family: var(--f-display);
      font-size: 1.3rem;
      font-weight: 400;
      letter-spacing: 0.04em;
      color: var(--cream);
      text-decoration: none;
      flex-shrink: 0;
    }

    /* Desktop links */
    .nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
      align-items: center;
    }
    .nav-links a {
      font-family: var(--f-body);
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--cream-dim);
      text-decoration: none;
      transition: color 0.2s;
      padding: 0.25rem 0;
    }
    .nav-links a:hover { color: var(--gold); }

    /* Hamburger */
    .nav-hamburger {
      display: none;
      flex-direction: column;
      justify-content: center;
      gap: 5px;
      width: 44px;
      height: 44px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 10px;
      margin-right: -10px;
      flex-shrink: 0;
    }
    .nav-hamburger span {
      display: block;
      height: 1.5px;
      background: var(--cream);
      transition: all 0.28s ease;
      transform-origin: center;
    }
    .nav-hamburger.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
    .nav-hamburger.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
    .nav-hamburger.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

    /* Mobile drawer */
    .nav-drawer {
      position: fixed;
      top: 60px; left: 0; right: 0;
      background: rgba(39,31,65,0.98);
      backdrop-filter: blur(18px);
      z-index: 190;
      padding: 1.5rem var(--pad-x) 2rem;
      opacity: 0;
      pointer-events: none;
      transform: translateY(-6px);
      transition: opacity 0.22s ease, transform 0.22s ease;
      border-bottom: 3px solid;
      border-image: linear-gradient(90deg, var(--rose), var(--plum), var(--violet), var(--coral), var(--gold)) 1;
    }
    .nav-drawer.open {
      opacity: 1;
      pointer-events: all;
      transform: translateY(0);
    }
    .nav-drawer ul { list-style: none; }
    .nav-drawer ul li a {
      display: block;
      font-family: var(--f-body);
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--cream-dim);
      text-decoration: none;
      padding: 1rem 0;
      border-bottom: 1px solid var(--rule);
      transition: color 0.2s;
    }
    .nav-drawer ul li:last-child a { border-bottom: none; }
    .nav-drawer ul li a:hover { color: var(--gold); }

    /* ════════════════════════════════════════════
       BUTTONS
    ════════════════════════════════════════════ */
    .btn-primary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-family: var(--f-body);
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--charcoal);
      background: var(--gold);
      padding: 1rem 2rem;
      text-decoration: none;
      transition: background 0.2s;
      min-height: 48px;
      white-space: nowrap;
    }
    .btn-primary:hover { background: var(--cream); }

    .btn-ghost {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-family: var(--f-body);
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--cream-dim);
      border: 1px solid var(--rule-hi);
      padding: 1rem 2rem;
      text-decoration: none;
      transition: border-color 0.2s, color 0.2s;
      min-height: 48px;
      white-space: nowrap;
    }
    .btn-ghost:hover { border-color: var(--rose); color: var(--rose); }

    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      align-items: center;
    }

    /* ════════════════════════════════════════════
       HERO
    ════════════════════════════════════════════ */
    .hero {
      padding: clamp(6.5rem, 14vw, 10rem) 0 clamp(4rem, 8vw, 7rem);
      position: relative;
      overflow: hidden;
    }
    /* Supergraphic: absolutely positioned, right side */
    .hero-sg {
      position: absolute;
      right: clamp(-80px, -5vw, -20px);
      top: clamp(20px, 5vw, 60px);
      width: min(460px, 52vw);
      pointer-events: none;
      opacity: 0.1;
    }
    .hero-eyebrow {
      font-family: var(--f-body);
      font-size: 0.68rem;
      font-weight: 600;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--rose);
      margin-bottom: 1.75rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }
    .hero-eyebrow::after {
      content: '';
      width: 36px;
      height: 2px;
      background: linear-gradient(90deg, var(--rose), var(--violet));
      flex-shrink: 0;
    }
    .hero-headline {
      font-family: var(--f-display);
      font-size: clamp(2.6rem, 7vw, 4.8rem);
      font-weight: 300;
      line-height: 1.1;
      letter-spacing: -0.01em;
      color: var(--cream);
      margin-bottom: 1.75rem;
    }
    .hero-headline em { font-style: italic; color: var(--gold); }
    .hero-body {
      max-width: 520px;
      color: var(--cream-dim);
      font-size: clamp(0.9rem, 2.5vw, 1rem);
      font-weight: 300;
      line-height: 1.85;
      margin-bottom: 2.75rem;
    }
    .hero-body strong { color: var(--cream); font-weight: 600; }

    /* ════════════════════════════════════════════
       MARQUEE
    ════════════════════════════════════════════ */
    .marquee-wrap {
      border-top: 1px solid var(--rule);
      border-bottom: 1px solid var(--rule);
      padding: 0.9rem 0;
      overflow: hidden;
    }
    .marquee-track {
      display: flex;
      width: max-content;
      animation: ticker 30s linear infinite;
    }
    .marquee-track:hover { animation-play-state: paused; }
    .marquee-item {
      font-family: var(--f-body);
      font-size: 0.62rem;
      font-weight: 600;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(245,242,236,0.18);
      padding: 0 2.5rem;
      white-space: nowrap;
      display: flex;
      align-items: center;
      gap: 2.5rem;
    }
    .marquee-item::after {
      content: '';
      width: 4px;
      height: 4px;
      border-radius: 50%;
      background: var(--rose);
      opacity: 0.5;
      flex-shrink: 0;
    }

    /* ════════════════════════════════════════════
       SECTION SHARED
    ════════════════════════════════════════════ */
    section { padding: clamp(4rem, 10vw, 6.5rem) 0; }

    .section-label {
      font-family: var(--f-body);
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--rose);
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }
    .section-label::after {
      content: '';
      width: 28px;
      height: 2px;
      background: linear-gradient(90deg, var(--rose), var(--violet));
      flex-shrink: 0;
    }
    .section-headline {
      font-family: var(--f-display);
      font-size: clamp(1.9rem, 4.5vw, 3.1rem);
      font-weight: 300;
      line-height: 1.15;
      color: var(--cream);
      margin-bottom: 1.5rem;
    }
    .section-headline em { font-style: italic; color: var(--gold); }
    .section-body {
      color: var(--cream-dim);
      font-weight: 300;
      line-height: 1.85;
      max-width: 560px;
      font-size: clamp(0.875rem, 2.2vw, 1rem);
    }

    /* ════════════════════════════════════════════
       WORK GRID
    ════════════════════════════════════════════ */
    .work-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      margin-top: 3.5rem;
      border: 1px solid var(--rule);
    }
    .work-item {
      padding: clamp(1.5rem, 4vw, 2.5rem);
      border-right: 1px solid var(--rule);
      border-bottom: 1px solid var(--rule);
      position: relative;
      overflow: hidden;
      transition: background 0.25s;
    }
    .work-item::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 2px;
      background: linear-gradient(90deg, var(--rose), var(--violet));
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.35s ease;
    }
    .work-item:hover::before { transform: scaleX(1); }
    .work-item:hover { background: rgba(255,255,255,0.025); }
    .work-item:nth-child(2n) { border-right: none; }
    .work-item:nth-last-child(-n+2) { border-bottom: none; }
    .work-number {
      font-family: var(--f-body);
      font-size: 0.6rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      color: var(--rose);
      opacity: 0.55;
      margin-bottom: 1rem;
    }
    .work-title {
      font-family: var(--f-display);
      font-size: clamp(1.1rem, 2.5vw, 1.45rem);
      font-weight: 400;
      color: var(--cream);
      margin-bottom: 0.75rem;
      line-height: 1.2;
    }
    .work-desc {
      font-size: clamp(0.82rem, 2vw, 0.9rem);
      font-weight: 300;
      color: var(--cream-dim);
      line-height: 1.75;
    }

    /* ════════════════════════════════════════════
       SPRINT OFFER
    ════════════════════════════════════════════ */
    .sprint-block {
      margin-top: 3.5rem;
      border: 1px solid var(--rule-hi);
      position: relative;
    }
    .sprint-block::before {
      content: '';
      position: absolute;
      top: -1px; left: 0; right: 0;
      height: 3px;
      background: linear-gradient(90deg, var(--rose), var(--plum), var(--violet), var(--coral), var(--gold));
    }
    .sprint-header {
      padding: clamp(1.5rem, 4vw, 2.5rem);
      border-bottom: 1px solid var(--rule);
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 2rem;
      align-items: start;
    }
    .sprint-name {
      font-family: var(--f-display);
      font-size: clamp(1.4rem, 3.5vw, 2rem);
      font-weight: 300;
      color: var(--cream);
      line-height: 1.2;
    }
    .sprint-meta { text-align: right; flex-shrink: 0; }
    .sprint-price {
      font-family: var(--f-display);
      font-size: clamp(1.8rem, 4vw, 2.4rem);
      font-weight: 300;
      color: var(--gold);
      line-height: 1;
    }
    .sprint-duration {
      font-family: var(--f-body);
      font-size: 0.67rem;
      font-weight: 300;
      letter-spacing: 0.12em;
      color: var(--cream-dim);
      margin-top: 0.5rem;
    }
    .sprint-body {
      padding: clamp(1.5rem, 4vw, 2.5rem);
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem;
    }
    .sprint-col-label {
      font-family: var(--f-body);
      font-size: 0.62rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--rose);
      margin-bottom: 1.25rem;
      padding-bottom: 0.75rem;
      border-bottom: 1px solid var(--rule);
    }
    .sprint-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.65rem;
    }
    .sprint-list li {
      font-size: clamp(0.82rem, 2vw, 0.9rem);
      font-weight: 300;
      color: var(--cream-dim);
      line-height: 1.55;
      padding-left: 1.25rem;
      position: relative;
    }
    .sprint-list li::before { content: '—'; position: absolute; left: 0; color: var(--violet); }
    .sprint-list.excluded li::before { color: var(--rule-hi); }
    .sprint-scope-note {
      margin-top: 1.25rem;
      font-size: 0.8rem;
      font-weight: 300;
      color: rgba(230,182,92,0.5);
      line-height: 1.65;
    }
    .sprint-footer {
      padding: clamp(1.25rem, 3vw, 2rem) clamp(1.5rem, 4vw, 2.5rem);
      border-top: 1px solid var(--rule);
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 1rem;
    }
    .sprint-caveat {
      font-family: var(--f-body);
      font-size: 0.67rem;
      font-weight: 300;
      letter-spacing: 0.1em;
      color: var(--cream-dim);
    }

    /* ════════════════════════════════════════════
       FIT
    ════════════════════════════════════════════ */
    .fit-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
      margin-top: 3.5rem;
    }
    .fit-card {
      padding: clamp(1.5rem, 4vw, 2.5rem);
      border: 1px solid var(--rule);
      position: relative;
    }
    .fit-card.yes {
      border-top: 3px solid transparent;
      border-image: linear-gradient(90deg, var(--rose), var(--violet)) 1;
    }
    .fit-card.no { border-top: 1px solid var(--rule-hi); }
    .fit-card-label {
      font-family: var(--f-body);
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--rose);
      margin-bottom: 1.5rem;
    }
    .fit-card.no .fit-card-label { color: var(--cream-dim); opacity: 0.45; }
    .fit-list { list-style: none; display: flex; flex-direction: column; gap: 0.8rem; }
    .fit-list li {
      font-size: clamp(0.82rem, 2vw, 0.9rem);
      font-weight: 300;
      color: var(--cream-dim);
      line-height: 1.55;
      padding-left: 1.25rem;
      position: relative;
    }
    .fit-card.yes .fit-list li::before { content: '↗'; position: absolute; left: 0; color: var(--gold); font-size: 0.7rem; }
    .fit-card.no  .fit-list li::before { content: '—';  position: absolute; left: 0; color: var(--rule-hi); }

    /* ════════════════════════════════════════════
       PROCESS
    ════════════════════════════════════════════ */
    .process-steps { margin-top: 3.5rem; display: flex; flex-direction: column; }
    .process-step {
      display: grid;
      grid-template-columns: 72px 1fr;
      border-top: 1px solid var(--rule);
      padding: clamp(1.5rem, 3.5vw, 2.25rem) 0;
      position: relative;
    }
    .process-step:last-child { border-bottom: 1px solid var(--rule); }
    .process-step::after {
      content: '';
      position: absolute;
      bottom: -1px; left: 0;
      height: 1px; width: 0;
      background: linear-gradient(90deg, var(--rose), var(--violet), var(--coral));
      transition: width 0.45s ease;
    }
    .process-step:hover::after { width: 100%; }
    .step-num {
      font-family: var(--f-display);
      font-size: clamp(2rem, 4vw, 2.6rem);
      font-weight: 300;
      color: var(--rule-hi);
      line-height: 1;
      padding-top: 0.15rem;
      transition: color 0.25s;
    }
    .process-step:hover .step-num { color: var(--plum); }
    .step-title {
      font-family: var(--f-display);
      font-size: clamp(1.1rem, 2.5vw, 1.35rem);
      font-weight: 400;
      color: var(--cream);
      margin-bottom: 0.4rem;
    }
    .step-desc {
      font-size: clamp(0.82rem, 2vw, 0.875rem);
      font-weight: 300;
      color: var(--cream-dim);
      line-height: 1.78;
      max-width: 520px;
    }

    /* ════════════════════════════════════════════
       POSITIONING
    ════════════════════════════════════════════ */
    .position-block {
      margin-top: 3.5rem;
      padding: clamp(2rem, 5vw, 3rem);
      border: 1px solid var(--rule);
      position: relative;
      background: rgba(255,255,255,0.02);
      overflow: hidden;
    }
    .pos-sg {
      position: absolute;
      right: -40px; top: -40px;
      width: 260px; height: 260px;
      opacity: 0.055;
      pointer-events: none;
    }
    .position-quote {
      font-family: var(--f-display);
      font-size: clamp(1.2rem, 3vw, 1.8rem);
      font-weight: 300;
      font-style: italic;
      line-height: 1.5;
      color: var(--cream);
      position: relative;
    }
    .position-sub {
      margin-top: 1.75rem;
      font-size: clamp(0.85rem, 2vw, 0.9rem);
      font-weight: 300;
      color: var(--cream-dim);
      line-height: 1.9;
      max-width: 560px;
    }

    /* ════════════════════════════════════════════
       CTA
    ════════════════════════════════════════════ */
    .cta-section {
      padding: clamp(5rem, 12vw, 8rem) 0;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .cta-sg {
      position: absolute;
      left: 50%; top: 50%;
      transform: translate(-50%, -50%);
      width: min(700px, 90vw);
      opacity: 0.05;
      pointer-events: none;
    }
    .cta-headline {
      font-family: var(--f-display);
      font-size: clamp(2.2rem, 6vw, 4rem);
      font-weight: 300;
      line-height: 1.12;
      color: var(--cream);
      margin-bottom: 1.5rem;
      position: relative;
    }
    .cta-headline em { font-style: italic; color: var(--gold); }
    .cta-body {
      color: var(--cream-dim);
      font-weight: 300;
      max-width: 420px;
      margin: 0 auto 2.75rem;
      font-size: clamp(0.9rem, 2.2vw, 0.975rem);
      line-height: 1.85;
      position: relative;
    }
    .cta-note {
      margin-top: 1.5rem;
      font-family: var(--f-body);
      font-size: 0.65rem;
      font-weight: 300;
      letter-spacing: 0.14em;
      color: rgba(230,182,92,0.45);
      position: relative;
    }

    /* ════════════════════════════════════════════
       FOOTER
    ════════════════════════════════════════════ */
    footer { border-top: 1px solid var(--rule); padding: 2.5rem 0 0; }
    .footer-inner {
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 0 var(--pad-x);
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 0.75rem;
    }
    .footer-logo {
      font-family: var(--f-display);
      font-size: 1.05rem;
      font-weight: 400;
      color: rgba(245,242,236,0.28);
    }
    .footer-copy {
      font-family: var(--f-body);
      font-size: 0.62rem;
      font-weight: 300;
      letter-spacing: 0.1em;
      color: rgba(230,182,92,0.28);
    }

    /* ════════════════════════════════════════════
       RESPONSIVE BREAKPOINTS
       — Mobile-first stacking, Squarespace-style:
         fluid type via clamp(), grids → single col,
         touch-safe 48px tap targets
    ════════════════════════════════════════════ */

    /* ── 720px: Show hamburger, hide desktop nav ── */
    @media (max-width: 720px) {
      .nav-links    { display: none; }
      .nav-hamburger { display: flex; }
    }

    /* ── 640px: Stack multi-column grids ── */
    @media (max-width: 640px) {
      /* Work grid → single column */
      .work-grid { grid-template-columns: 1fr; }
      .work-item { border-right: none !important; }
      .work-item:not(:last-child) { border-bottom: 1px solid var(--rule); }
      .work-item:last-child { border-bottom: none; }

      /* Sprint → stack meta below name */
      .sprint-header { grid-template-columns: 1fr; }
      .sprint-meta   { text-align: left; }
      .sprint-body   { grid-template-columns: 1fr; gap: 2rem; }
      .sprint-footer { flex-direction: column; align-items: flex-start; }
      .sprint-footer .btn-primary { width: 100%; }

      /* Fit cards → stack */
      .fit-grid { grid-template-columns: 1fr; }
    }

    /* ── 480px: Tightest viewport (older iPhones) ── */
    @media (max-width: 480px) {
      /* Full-width CTAs */
      .hero-actions  { flex-direction: column; }
      .btn-primary, .btn-ghost { width: 100%; text-align: center; }
      .cta-section .btn-primary { width: 100%; max-width: 360px; }

      /* Process step number column narrower */
      .process-step { grid-template-columns: 52px 1fr; }

      /* Footer stack */
      .footer-inner { flex-direction: column; align-items: flex-start; }
    }

    /* ════════════════════════════════════════════
       ACCESSIBILITY: Reduced motion
    ════════════════════════════════════════════ */
    @media (prefers-reduced-motion: reduce) {
      .fade-up          { animation: none; opacity: 1; transform: none; }
      .marquee-track    { animation: none; }
      .process-step::after { transition: none; }
      .work-item::before   { transition: none; }
      .reveal           { opacity: 1 !important; transform: none !important; transition: none !important; }
    }

    /* ════════════════════════════════════════════
       SCROLL REVEAL — IntersectionObserver driven
       Elements start invisible, fade+slide in when
       they enter the viewport (Squarespace-style)
    ════════════════════════════════════════════ */
    .reveal {
      opacity: 0;
      transform: translateY(28px);
      transition: opacity 0.7s cubic-bezier(0.22,1,0.36,1),
                  transform 0.7s cubic-bezier(0.22,1,0.36,1);
    }
    .reveal.revealed {
      opacity: 1;
      transform: translateY(0);
    }
    .reveal-delay-1 { transition-delay: 0.1s; }
    .reveal-delay-2 { transition-delay: 0.2s; }
    .reveal-delay-3 { transition-delay: 0.3s; }
    .reveal-delay-4 { transition-delay: 0.4s; }

    /* ════════════════════════════════════════════
       MOBILE STICKY CTA BAR
       Shows on mobile when hero CTA scrolls out.
       Hidden on desktop.
    ════════════════════════════════════════════ */
    .sticky-cta {
      display: none; /* hidden by default; JS shows it on mobile */
      position: fixed;
      bottom: 0; left: 0; right: 0;
      z-index: 300;
      background: var(--charcoal);
      border-top: 1px solid var(--rule-hi);
      padding: 0.85rem var(--pad-x);
      padding-bottom: calc(0.85rem + var(--safe-bottom));
      transition: transform 0.3s ease, opacity 0.3s ease;
      transform: translateY(100%);
      opacity: 0;
    }
    .sticky-cta.visible {
      transform: translateY(0);
      opacity: 1;
    }
    .sticky-cta-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      max-width: var(--max-w);
      margin: 0 auto;
    }
    .sticky-cta-label {
      font-family: var(--f-body);
      font-size: 0.72rem;
      font-weight: 300;
      color: var(--cream-dim);
      letter-spacing: 0.04em;
      flex: 1;
      line-height: 1.4;
    }
    .sticky-cta .btn-primary {
      flex-shrink: 0;
      font-size: 0.68rem;
      padding: 0.75rem 1.5rem;
      min-height: 44px;
    }
    /* Show sticky CTA only on mobile */
    @media (max-width: 720px) {
      .sticky-cta { display: block; }
      /* Add breathing room above sticky bar */
      body.sticky-visible { padding-bottom: var(--sticky-cta-h); }
    }

    /* ════════════════════════════════════════════
       MOBILE TOUCH + SPACING REFINEMENTS
    ════════════════════════════════════════════ */

    /* Safe-area nav padding for notched phones */
    nav {
      padding-top: var(--safe-top);
    }
    .nav-inner {
      height: calc(60px + var(--safe-top));
      padding-top: var(--safe-top);
    }
    .nav-drawer {
      top: calc(60px + var(--safe-top));
    }

    /* Ensure hero top padding accounts for taller nav on notched phones */
    .hero {
      padding-top: calc(clamp(6.5rem, 14vw, 10rem) + var(--safe-top));
    }

    /* ════════════════════════════════════════════
       480px — Smallest viewports (older iPhones)
    ════════════════════════════════════════════ */
    @media (max-width: 480px) {
      /* Full-width CTAs */
      .hero-actions  { flex-direction: column; }
      .btn-primary, .btn-ghost {
        width: 100%;
        text-align: center;
        justify-content: center;
      }
      .cta-section .btn-primary { width: 100%; max-width: 100%; }

      /* Process step — tighter number column */
      .process-step { grid-template-columns: 48px 1fr; gap: 0; }
      .step-num { font-size: 1.8rem; }

      /* Footer stack */
      .footer-inner { flex-direction: column; align-items: flex-start; gap: 0.5rem; }

      /* Sprint footer stack */
      .sprint-footer { flex-direction: column; align-items: stretch; }
      .sprint-footer .btn-primary { width: 100%; text-align: center; justify-content: center; }

      /* Section headline tighter on very small screens */
      .section-headline { letter-spacing: -0.015em; }

      /* Position block padding reduction */
      .position-block { padding: 1.5rem; }
      .pos-sg { display: none; } /* hide decorative SVG on smallest screens */

      /* Reduce marquee padding */
      .marquee-item { padding: 0 1.5rem; }
    }

    /* ════════════════════════════════════════════
       TOUCH: Larger tap areas, no hover artifacts
    ════════════════════════════════════════════ */
    @media (hover: none) and (pointer: coarse) {
      /* Remove hover-only decorations that feel broken on touch */
      .work-item::before      { display: none; }
      .process-step::after    { display: none; }

      /* Increase tap target padding on nav links */
      .nav-drawer ul li a     { padding: 1.1rem 0; min-height: 52px; display: flex; align-items: center; }

      /* Remove hover state color shifts */
      .btn-primary:hover      { background: var(--gold); }
      .btn-ghost:hover        { border-color: var(--rule-hi); color: var(--cream-dim); }

      /* Work item touch feedback */
      .work-item:active       { background: rgba(255,255,255,0.04); }
    }

  </style>
</head>
