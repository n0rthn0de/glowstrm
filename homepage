<script>
  /* ── NAV HAMBURGER ── */
  const hamburger = document.getElementById('hamburger');
  const drawer    = document.getElementById('navDrawer');

  function closeNav() {
    hamburger.classList.remove('open');
    drawer.classList.remove('open');
    hamburger.setAttribute('aria-expanded', 'false');
  }
  function openNav() {
    hamburger.classList.add('open');
    drawer.classList.add('open');
    hamburger.setAttribute('aria-expanded', 'true');
  }

  hamburger.addEventListener('click', (e) => {
    e.stopPropagation();
    drawer.classList.contains('open') ? closeNav() : openNav();
  });

  document.addEventListener('click', (e) => {
    if (!hamburger.contains(e.target) && !drawer.contains(e.target)) closeNav();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeNav();
  });

  /* ── SCROLL REVEAL (IntersectionObserver) ── */
  // Add .reveal to all section content blocks
  const revealTargets = [
    '.section-label', '.section-headline', '.section-body',
    '.work-grid', '.sprint-block', '.fit-grid',
    '.process-step', '.position-block',
    '.cta-headline', '.cta-body',
    '.marquee-wrap'
  ];
  revealTargets.forEach((sel, si) => {
    document.querySelectorAll(sel).forEach((el, i) => {
      el.classList.add('reveal');
      // Stagger process steps
      if (sel === '.process-step') {
        const delay = Math.min(i * 0.08, 0.32);
        el.style.transitionDelay = delay + 's';
      }
      // Stagger work grid items inside work-grid
      if (sel === '.work-grid') {
        el.querySelectorAll('.work-item').forEach((item, j) => {
          item.classList.add('reveal');
          item.style.transitionDelay = (j * 0.1) + 's';
        });
      }
    });
  });

  const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('revealed');
        revealObserver.unobserve(entry.target);
      }
    });
  }, {
    threshold: 0.08,
    rootMargin: '0px 0px -40px 0px'
  });

  document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

  /* ── MOBILE STICKY CTA ── */
  const stickyCta  = document.getElementById('stickyCta');
  const heroAction = document.querySelector('.hero-actions');

  if (stickyCta && heroAction && window.innerWidth <= 720) {
    const heroObserver = new IntersectionObserver((entries) => {
      const heroVisible = entries[0].isIntersecting;
      if (heroVisible) {
        stickyCta.classList.remove('visible');
        document.body.classList.remove('sticky-visible');
      } else {
        stickyCta.classList.add('visible');
        document.body.classList.add('sticky-visible');
      }
    }, { threshold: 0, rootMargin: '0px 0px -20px 0px' });

    heroObserver.observe(heroAction);
  }

  /* ── NAV ACTIVE STATE on scroll ── */
  const sections = document.querySelectorAll('section[id], div.hero');
  const navLinks = document.querySelectorAll('.nav-links a, .nav-drawer a');

  const activeObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const id = entry.target.id || 'hero';
        navLinks.forEach(link => {
          link.style.color = '';
          if (link.getAttribute('href') === '#' + id) {
            link.style.color = 'var(--gold)';
          }
        });
      }
    });
  }, { threshold: 0.4 });

  sections.forEach(s => activeObserver.observe(s));

  /* ── SMOOTH DRAWER CLOSE on nav link tap ── */
  document.querySelectorAll('.nav-drawer a').forEach(a => {
    a.addEventListener('click', closeNav);
  });
